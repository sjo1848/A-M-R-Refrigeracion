---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/sections/Header.astro';
import Footer from '../components/sections/Footer.astro';
import FloatingWhatsapp from '../components/sections/FloatingWhatsapp.astro';
import MobileActionBar from '../components/sections/MobileActionBar.astro';
import { amrContent } from '../content/amr';
import { buildTelUrl, buildWhatsAppUrl } from '../utils/whatsapp';

const whatsappUrl = buildWhatsAppUrl(
  amrContent.contact.whatsapp,
  'Hola, no encontré la página que buscaba en la web, ¿podrían ayudarme?',
  '404'
);
const phoneUrl = buildTelUrl(amrContent.contact.phoneLabel);
---

<BaseLayout
  title="Página no encontrada | A.M.R. Refrigeración"
  description="Lo sentimos, la página que buscas no existe o ha sido movida."
>
  <Header
    brandName={amrContent.brand.name}
    whatsappUrl={whatsappUrl}
    phoneUrl={phoneUrl}
    callLabel={amrContent.cta.callLabel}
  />

  <main class="flex min-h-[70vh] flex-col items-center justify-center px-4 text-center">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-brand-soft)]">Error de navegación</p>
    <h1 class="mt-3 text-7xl font-black text-[var(--color-text)] md:text-8xl">404</h1>
    <p class="mt-4 text-2xl font-bold text-[var(--color-text)] md:text-3xl">Página no encontrada</p>

    <p class="mb-10 mt-5 max-w-md text-lg text-[var(--color-text-muted)]">
      La dirección puede haber cambiado o el enlace no es correcto. Volvé al inicio o escribinos por WhatsApp.
    </p>

    <div class="flex flex-col items-center gap-4 sm:flex-row">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-xl bg-[var(--color-brand)] px-8 py-4 text-sm font-bold text-white transition hover:opacity-90"
      >
        Volver al inicio
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-8 py-4 text-sm font-bold text-[var(--color-text)] transition hover:border-[var(--color-whatsapp)]"
      >
        Consultar por WhatsApp
      </a>
    </div>
  </main>

  <Footer
    brandName={amrContent.brand.name}
    businessLabel={amrContent.footer.businessLabel}
    phoneLabel={amrContent.contact.phoneLabel}
    phoneUrl={phoneUrl}
    addressReference={amrContent.footer.addressReference}
    coverageLabel={amrContent.footer.coverageLabel}
    serviceConditions={amrContent.legal.serviceConditions}
    commercialNotice={amrContent.legal.commercialNotice}
  />
  <FloatingWhatsapp whatsappUrl={whatsappUrl} />
  <MobileActionBar
    whatsappUrl={whatsappUrl}
    phoneUrl={phoneUrl}
    whatsappLabel="WhatsApp"
    callLabel={amrContent.cta.callLabel}
  />
</BaseLayout>
