---
// src/pages/servicios/[slug].astro
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import FloatingWhatsapp from '../../components/sections/FloatingWhatsapp.astro';
import { amrContent } from '../../content/amr';
import { buildTelUrl, buildWhatsAppUrl } from '../../utils/whatsapp';
import { buildLocalBusinessSchema } from '../../utils/seo';

// Generar rutas dinámicas para cada servicio
export async function getStaticPaths() {
  return amrContent.servicesDetails.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const whatsappBaseUrl = buildWhatsAppUrl(
  amrContent.contact.whatsapp,
  amrContent.cta.whatsappMessage,
);
const phoneUrl = buildTelUrl(amrContent.contact.phoneLabel);
const whatsappHeaderUrl = buildWhatsAppUrl(
  amrContent.contact.whatsapp,
  amrContent.cta.whatsappMessage,
  'header'
);
const whatsappServiceUrl = buildWhatsAppUrl(
  amrContent.contact.whatsapp,
  `Hola, necesito consultar por el servicio de: ${service.title}.\nEstoy en Mendoza.`,
  'servicio-detalle'
);

const siteUrl = import.meta.env.PUBLIC_SITE_URL;
const canonical = siteUrl ? new URL(Astro.url.pathname, siteUrl).toString() : Astro.url.toString();

// Configuración de Schema enriquecido para el servicio específico
const schema = buildLocalBusinessSchema(amrContent, new URL(canonical), whatsappBaseUrl);

const localImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/gallery/*.{jpeg,jpg,png,gif,webp}', {
  eager: true,
});

const resolveLocalImage = (imageRef: string | undefined) => {
  if (!imageRef) return null;
  const filename = imageRef.split('/').pop();
  if (!filename) return null;
  const match = Object.keys(localImages).find((path) => path.endsWith(`/${filename}`));
  return match ? localImages[match].default : null;
};

const serviceImage = resolveLocalImage(service.relatedGalleryImages[0]);
---

<BaseLayout
  title={service.seoTitle}
  description={service.seoDescription}
  keywords={amrContent.seo.keywords + `, ${service.title.toLowerCase()}`}
  canonical={canonical}
  schema={schema}
>
  <Header
    brandName={amrContent.brand.name}
    whatsappUrl={whatsappHeaderUrl}
    phoneUrl={phoneUrl}
    callLabel={amrContent.cta.callLabel}
  />
  
  <main class="flex-grow pt-24 pb-16">
    <div class="container-shell">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-[var(--color-brand-soft)] mb-4">Servicio Técnico Especializado</p>
        <h1 class="text-4xl md:text-5xl font-extrabold text-[var(--color-text)] tracking-tight text-pretty mb-6">
          {service.title}
        </h1>
        <p class="text-lg md:text-xl text-[var(--color-text-muted)] text-pretty leading-relaxed">
          {service.description}
        </p>
      </div>

      <div class="mt-16 grid md:grid-cols-2 gap-12 items-center bg-[var(--color-surface)]/40 rounded-3xl p-8 md:p-12 border border-white/5">
        <div>
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">¿Qué incluye nuestro servicio?</h2>
          <ul class="space-y-4">
            {service.features.map((feature: string) => (
              <li class="flex items-start gap-3 text-[var(--color-text-muted)]">
                <span class="mt-1 shrink-0 p-1 rounded-full bg-[var(--color-whatsapp)]/20 text-[var(--color-whatsapp)]">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          
          <div class="mt-10">
            <a
              href={whatsappServiceUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-whatsapp)] px-8 py-4 text-base font-extrabold text-white transition hover:bg-[var(--color-whatsapp-hover)] hover:-translate-y-1 shadow-lg shadow-[var(--color-whatsapp)]/20"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.436 3 12c0 1.605.498 3.093 1.348 4.31l-1.373 3.513a.563.563 0 0 0 .717.717l3.513-1.373A8.932 8.932 0 0 0 12 20.252Zm0-13.5c4.142 0 7.5 3.023 7.5 6.75s-3.358 6.75-7.5 6.75A7.47 7.47 0 0 1 6.55 19.3l-2.036.796.796-2.036A7.47 7.47 0 0 1 4.5 12c0-3.727 3.358-6.75 7.5-6.759Z" />
              </svg>
              Solicitar Presupuesto
            </a>
          </div>
        </div>
        
        <div class="relative w-full aspect-square md:aspect-auto md:h-full rounded-2xl overflow-hidden shadow-2xl border border-white/10">
            {serviceImage ? (
              <Image
                src={serviceImage}
                alt={`Técnico trabajando en ${service.title.toLowerCase()}`}
                width={1200}
                class="w-full h-full object-cover"
              />
            ) : (
              <img
                src="/images/placeholder-work.svg"
                alt={`Técnico trabajando en ${service.title.toLowerCase()}`}
                class="w-full h-full object-cover"
              />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-6 left-6 right-6 flex items-center gap-3">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white text-black">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
                   <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm11.378-3.917c-.89-.777-2.366-.149-2.366 1.041v5.752c0 1.19 1.476 1.818 2.366 1.041l4.536-3.951a1.5 1.5 0 0 0 0-2.264l-4.536-3.951Z" clip-rule="evenodd" />
                </svg>
              </span>
              <p class="text-white font-semibold text-sm">Respuesta en breve por WhatsApp</p>
            </div>
        </div>
      </div>
    </div>
  </main>
  
  <Footer
    brandName={amrContent.brand.name}
    businessLabel={amrContent.footer.businessLabel}
    phoneLabel={amrContent.contact.phoneLabel}
    phoneUrl={phoneUrl}
    addressReference={amrContent.footer.addressReference}
    coverageLabel={amrContent.footer.coverageLabel}
  />
  <FloatingWhatsapp whatsappUrl={whatsappServiceUrl} />
</BaseLayout>
