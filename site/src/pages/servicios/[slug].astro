---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';
import FloatingWhatsapp from '../../components/sections/FloatingWhatsapp.astro';
import MobileActionBar from '../../components/sections/MobileActionBar.astro';
import { amrContent } from '../../content/amr';
import { buildTelUrl, buildWhatsAppUrl } from '../../utils/whatsapp';
import { buildLocalBusinessSchema } from '../../utils/seo';

export async function getStaticPaths() {
  return amrContent.servicesDetails.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const whatsappBaseUrl = buildWhatsAppUrl(
  amrContent.contact.whatsapp,
  amrContent.cta.whatsappMessage,
);
const phoneUrl = buildTelUrl(amrContent.contact.phoneLabel);
const whatsappHeaderUrl = buildWhatsAppUrl(
  amrContent.contact.whatsapp,
  amrContent.cta.whatsappMessage,
  'header'
);
const whatsappServiceUrl = buildWhatsAppUrl(
  amrContent.contact.whatsapp,
  `Hola, necesito consultar por el servicio de: ${service.title}.\nEstoy en Mendoza.`,
  'servicio-detalle'
);
const instagramUrl = import.meta.env.PUBLIC_INSTAGRAM_URL ?? '';

const siteUrl = import.meta.env.PUBLIC_SITE_URL;
const canonical = siteUrl ? new URL(Astro.url.pathname, siteUrl).toString() : Astro.url.toString();
const schema = buildLocalBusinessSchema(amrContent, new URL(canonical), whatsappBaseUrl);

const localImages = import.meta.glob<{ default: ImageMetadata }>('../../assets/gallery/*.{jpeg,jpg,png,gif,webp}', {
  eager: true,
});

const resolveLocalImage = (imageRef: string | undefined) => {
  if (!imageRef) return null;
  const filename = imageRef.split('/').pop();
  if (!filename) return null;
  const match = Object.keys(localImages).find((path) => path.endsWith(`/${filename}`));
  return match ? localImages[match].default : null;
};

const serviceImage = resolveLocalImage(service.relatedGalleryImages[0]);
---

<BaseLayout
  title={service.seoTitle}
  description={service.seoDescription}
  keywords={amrContent.seo.keywords + `, ${service.title.toLowerCase()}`}
  canonical={canonical}
  schema={schema}
>
  <Header
    brandName={amrContent.brand.name}
    whatsappUrl={whatsappHeaderUrl}
    phoneUrl={phoneUrl}
    callLabel={amrContent.cta.callLabel}
  />

  <main class="flex-grow pb-16 pt-24">
    <div class="container-shell">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 text-xs font-extrabold uppercase tracking-[0.16em] text-[var(--color-brand-soft)]">Servicio técnico especializado</p>
        <h1 class="mb-6 text-4xl font-extrabold tracking-tight text-[var(--color-text)] text-pretty md:text-5xl">
          {service.title}
        </h1>
        <p class="text-pretty text-lg leading-relaxed text-[var(--color-text-muted)] md:text-xl">
          {service.description}
        </p>
      </div>

      <div class="mt-14 grid items-center gap-10 rounded-3xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 md:grid-cols-2 md:p-10">
        <div>
          <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">¿Qué incluye nuestro servicio?</h2>
          <ul class="space-y-4">
            {service.features.map((feature: string) => (
              <li class="flex items-start gap-3 text-[var(--color-text-muted)]">
                <span class="mt-1 shrink-0 rounded-full bg-[var(--color-whatsapp)]/18 p-1 text-[var(--color-whatsapp)]">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="size-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>

          <div class="mt-7 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-4">
            <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-[var(--color-brand-soft)]">Caso real resuelto</p>
            <div class="mt-3 space-y-2 text-sm text-[var(--color-text)]">
              <p><span class="font-bold">Falla:</span> {service.caseStudy.problem}</p>
              <p><span class="font-bold">Solucion:</span> {service.caseStudy.solution}</p>
              <p><span class="font-bold">Resultado:</span> {service.caseStudy.result}</p>
            </div>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.06em] text-[var(--color-text)]">
                Tecnico matriculado
              </span>
              <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.06em] text-[var(--color-text)]">
                Garantia segun trabajo
              </span>
            </div>
          </div>

          <div class="mt-10">
            <a
              href={whatsappServiceUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-whatsapp)] px-8 py-4 text-base font-extrabold text-white transition hover:bg-[var(--color-whatsapp-hover)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.436 3 12c0 1.605.498 3.093 1.348 4.31l-1.373 3.513a.563.563 0 0 0 .717.717l3.513-1.373A8.932 8.932 0 0 0 12 20.252Zm0-13.5c4.142 0 7.5 3.023 7.5 6.75s-3.358 6.75-7.5 6.75A7.47 7.47 0 0 1 6.55 19.3l-2.036.796.796-2.036A7.47 7.47 0 0 1 4.5 12c0-3.727 3.358-6.75 7.5-6.759Z" />
              </svg>
              Pedir presupuesto por WhatsApp
            </a>
          </div>
        </div>

        <div class="relative aspect-square w-full overflow-hidden rounded-2xl border border-[var(--color-border)] md:aspect-auto md:h-full">
          {serviceImage ? (
            <Image
              src={serviceImage}
              alt={`Técnico trabajando en ${service.title.toLowerCase()}`}
              width={1200}
              class="h-full w-full object-cover"
            />
          ) : (
            <img
              src="/images/placeholder-work.svg"
              alt={`Técnico trabajando en ${service.title.toLowerCase()}`}
              class="h-full w-full object-cover"
            />
          )}
          <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-5">
            <p class="text-sm font-semibold text-white">Atención técnica con respuesta por WhatsApp</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer
    brandName={amrContent.brand.name}
    businessLabel={amrContent.footer.businessLabel}
    phoneLabel={amrContent.contact.phoneLabel}
    phoneUrl={phoneUrl}
    instagramUrl={instagramUrl}
    addressReference={amrContent.footer.addressReference}
    coverageLabel={amrContent.footer.coverageLabel}
    serviceConditions={amrContent.legal.serviceConditions}
    commercialNotice={amrContent.legal.commercialNotice}
  />
  <FloatingWhatsapp whatsappUrl={whatsappServiceUrl} />
  <MobileActionBar
    whatsappUrl={whatsappServiceUrl}
    phoneUrl={phoneUrl}
    whatsappLabel="Pedir presupuesto"
    callLabel={amrContent.cta.callLabel}
  />
</BaseLayout>
