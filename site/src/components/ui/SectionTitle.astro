---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-8 max-w-3xl">
  {eyebrow && (
    <div class="mb-3 inline-flex items-center gap-2">
      <span class="h-[2px] w-7 bg-[var(--color-brand-soft)]"></span>
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-brand-soft)]">{eyebrow}</p>
    </div>
  )}
  <h2 class="text-3xl font-extrabold leading-[1.05] text-[var(--color-text)] md:text-4xl">{title}</h2>
  {description && <p class="mt-3 max-w-2xl text-[var(--color-text-muted)]">{description}</p>}
</header>
