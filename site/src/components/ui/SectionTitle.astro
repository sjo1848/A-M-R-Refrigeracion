---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-8 max-w-2xl">
  {eyebrow && <p class="mb-2 text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-brand-soft)]">{eyebrow}</p>}
  <h2 class="text-2xl font-extrabold text-[var(--color-text)] md:text-3xl">{title}</h2>
  {description && <p class="mt-3 text-[var(--color-text-muted)]">{description}</p>}
</header>
