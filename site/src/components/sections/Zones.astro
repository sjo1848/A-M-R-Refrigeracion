---
import SectionTitle from '../ui/SectionTitle.astro';

interface Props {
  zones: string[];
  coverageText: string;
}

const { zones, coverageText } = Astro.props;
---

<section class="py-14" id="cobertura">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Cobertura"
      title="Zonas de atencion en Mendoza"
      description="Cobertura real en Gran Mendoza."
    />
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 md:p-10 shadow-sm">
      <ul class="grid gap-4 text-sm font-bold text-[var(--color-text)] sm:grid-cols-2 lg:grid-cols-3">
        {zones.map((zone) => (
          <li class="flex items-center gap-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-soft)]/70 px-5 py-4 transition-colors hover:border-[var(--color-brand-soft)]/40">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5 text-[var(--color-brand-soft)]">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <span>{zone}</span>
          </li>
        ))}
      </ul>
      <div class="mt-8 flex items-start gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-4 py-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="mt-0.5 size-5 shrink-0 text-[var(--color-brand-soft)]">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z" />
        </svg>
        <p class="text-sm font-semibold leading-relaxed text-[var(--color-text)]">{coverageText}</p>
      </div>
    </div>
  </div>
</section>
