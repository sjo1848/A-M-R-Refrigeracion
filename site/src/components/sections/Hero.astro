---
interface Props {
  businessName: string;
  h1: string;
  descriptor: string;
  subtitle: string;
  locationLabel: string;
  responseTimeLabel: string;
  checks: string[];
  whatsappUrl: string;
  ctaLabel: string;
}

const {
  businessName,
  h1,
  descriptor,
  subtitle,
  locationLabel,
  responseTimeLabel,
  checks,
  whatsappUrl,
  ctaLabel,
} = Astro.props;
---

<section class="relative overflow-hidden pt-24 pb-16 md:pt-32 md:pb-24">
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-0 left-1/4 h-[35rem] w-[35rem] -translate-x-1/2 -translate-y-1/2 rounded-[100%] bg-[var(--color-brand)]/20 mix-blend-screen blur-[120px] opacity-70"></div>
    <div class="absolute bottom-0 right-1/4 h-[30rem] w-[30rem] translate-x-1/3 translate-y-1/3 rounded-[100%] bg-[var(--color-brand-soft)]/15 mix-blend-screen blur-[100px] opacity-60"></div>
  </div>
  <div class="container-shell relative z-10 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div class="animate-on-scroll is-visible">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[var(--color-brand-soft)]/30 bg-[var(--color-brand)]/10 px-4 py-1.5 backdrop-blur-sm">
        <span class="h-2 w-2 rounded-full bg-[var(--color-brand-soft)] shadow-[0_0_8px_var(--color-brand-soft)]"></span>
        <span class="text-sm font-bold tracking-wide uppercase text-[var(--color-text)]">{businessName}</span>
      </div>
      <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-white md:text-5xl lg:text-6xl">
        {h1}
      </h1>
      <p class="mt-6 text-sm font-bold uppercase tracking-[0.16em] text-[var(--color-brand-soft)]/90 drop-shadow-sm">{descriptor}</p>
      <p class="mt-4 max-w-xl text-lg leading-relaxed text-[var(--color-text-muted)] lg:text-xl">{subtitle}</p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <p class="text-sm font-medium text-[var(--color-text-muted)] flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--color-brand-soft)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          {locationLabel}
        </p>
      </div>
      <ul class="mt-6 grid gap-3 text-sm font-medium text-[var(--color-text)] sm:grid-cols-2">
        {checks.map((check) => (
          <li class="flex items-start gap-2.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 w-4 h-4 shrink-0 text-[var(--color-whatsapp)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{check}</span>
          </li>
        ))}
      </ul>
      <div class="mt-10 relative inline-flex">
        <!-- Glow pulse background -->
        <div class="absolute -inset-1 rounded-2xl bg-[var(--color-whatsapp)]/30 opacity-70 blur-md animate-pulse"></div>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noreferrer"
          class="relative group/btn inline-flex items-center justify-center gap-2.5 rounded-2xl bg-[var(--color-whatsapp)] px-7 py-4 font-bold text-white shadow-lg shadow-[var(--color-whatsapp)]/25 transition-all duration-300 hover:-translate-y-1 hover:bg-[var(--color-whatsapp-hover)] hover:shadow-xl hover:shadow-[var(--color-whatsapp)]/40 active:translate-y-0"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform duration-300 group-hover/btn:scale-110 group-hover/btn:-rotate-12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.868-2.03-.967-.272-.099-.47-.148-.668.148-.198.297-.767.967-.94 1.165-.173.198-.346.223-.643.074-.297-.149-1.255-.463-2.39-1.475-.882-.788-1.478-1.761-1.65-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.496.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.569-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.82 11.82 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.8 11.8 0 0 0-3.48-8.413z"/></svg>
          {ctaLabel}
        </a>
      </div>
    </div>
    <aside class="float-slow animate-on-scroll is-visible delay-100 relative rounded-[2rem] border border-white/5 bg-[var(--color-surface)]/40 p-1 backdrop-blur-md lg:ml-auto lg:w-full lg:max-w-md shadow-2xl">
      <div class="absolute inset-0 z-0 rounded-[2rem] bg-gradient-to-br from-white/10 to-transparent pointer-events-none"></div>
      <div class="relative z-10 rounded-[1.75rem] bg-[var(--color-surface-soft)]/60 p-7 md:p-8 border border-white/5">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-brand-soft)]">{responseTimeLabel}</p>
        <p class="mt-4 text-2xl font-bold leading-tight text-white drop-shadow-sm">Directo por WhatsApp para urgencias y presupuestos.</p>
        <p class="mt-4 text-sm leading-relaxed text-[var(--color-text-muted)]">
          En menos de dos pasos el cliente puede escribir, enviar fotos y recibir una respuesta clara.
        </p>
        <div class="mt-8 rounded-2xl border border-white/10 bg-black/40 p-5 shadow-inner">
          <p class="text-[10px] font-bold uppercase tracking-[0.16em] text-[var(--color-text-muted)] opacity-80">Cobertura confirmada</p>
          <div class="mt-3 inline-flex items-center gap-2">
            <span class="relative flex h-3 w-3">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
            </span>
            <p class="text-sm font-semibold capitalize tracking-wide text-white">{locationLabel}</p>
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>
