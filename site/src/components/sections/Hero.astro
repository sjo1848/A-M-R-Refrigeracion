---
import { Image } from 'astro:assets';
import defaultHeroBackground from '../../assets/gallery/amr-04.jpg';

interface Props {
  businessName: string;
  h1: string;
  descriptor: string;
  subtitle: string;
  mobileSubtitle?: string;
  locationLabel: string;
  responseTimeLabel: string;
  checks: string[];
  whatsappUrl: string;
  phoneUrl: string;
  ctaLabel: string;
  callLabel: string;
  topServiceLabel?: string;
  topServiceHref?: string;
  commercialNotice?: string;
  backgroundImage?: ImageMetadata;
}

const {
  businessName,
  h1,
  descriptor,
  subtitle,
  mobileSubtitle = 'Tecnico matriculado en Mendoza. Diagnostico y presupuesto por WhatsApp antes de intervenir.',
  locationLabel,
  responseTimeLabel,
  checks,
  whatsappUrl,
  phoneUrl,
  ctaLabel,
  callLabel,
  topServiceLabel = 'Servicio mas solicitado: Aire acondicionado automotor',
  topServiceHref = '/servicios/aire-acondicionado-automotor-mendoza',
  commercialNotice = 'Diagnostico y presupuesto informados antes de intervenir.',
  backgroundImage = defaultHeroBackground,
} = Astro.props;
---

<section class="relative isolate overflow-hidden pt-22 pb-12 md:pt-30 md:pb-18">
  <Image
    src={backgroundImage}
    alt=""
    widths={[640, 960, 1280, 1600]}
    sizes="(max-width: 768px) 100vw, 1600px"
    loading="eager"
    decoding="async"
    width={1600}
    class="absolute inset-0 -z-20 h-full w-full object-cover"
  />
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(100deg,rgba(3,18,35,0.86)_0%,rgba(6,26,45,0.74)_48%,rgba(8,35,60,0.6)_100%)]"></div>
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_10%_18%,rgba(49,155,225,0.22),transparent_40%),radial-gradient(circle_at_88%_80%,rgba(17,83,130,0.22),transparent_45%)]"></div>

  <div class="container-shell grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
    <div class="animate-on-scroll is-visible">
      <div class="mb-4 inline-flex items-center gap-2 rounded-md border border-white/25 bg-white/10 px-3 py-1.5 backdrop-blur-sm">
        <span class="h-2 w-2 rounded-full bg-sky-300"></span>
        <span class="text-xs font-extrabold uppercase tracking-[0.14em] text-white">{businessName}</span>
      </div>

      <a
        href={topServiceHref}
        class="mb-5 inline-flex items-center gap-2 rounded-md border border-sky-300/55 bg-sky-300/15 px-3 py-1.5 text-[11px] font-bold uppercase tracking-[0.12em] text-sky-100 transition-colors hover:bg-sky-300/22"
      >
        <span class="h-2 w-2 rounded-full bg-sky-300"></span>
        {topServiceLabel}
      </a>

      <p class="text-xs font-bold uppercase tracking-[0.2em] text-sky-200">{descriptor}</p>
      <h1 class="mt-3 text-[2.45rem] font-extrabold leading-[0.94] tracking-tight text-white sm:text-5xl md:text-6xl">
        {h1}
      </h1>
      <p class="mt-5 max-w-2xl text-[1.02rem] leading-relaxed text-slate-200 md:hidden">{mobileSubtitle}</p>
      <p class="mt-5 hidden max-w-2xl text-[1.05rem] leading-relaxed text-slate-200 md:block lg:text-xl">{subtitle}</p>

      <div class="mt-6 flex items-center gap-2 text-sm font-semibold text-slate-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sky-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>{locationLabel}</span>
      </div>

      <ul class="mt-6 grid gap-3 text-sm font-medium text-white sm:grid-cols-2">
        {checks.map((check) => (
          <li class="flex items-start gap-2 rounded-lg border border-white/20 bg-white/10 px-3 py-2 backdrop-blur-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 shrink-0 text-emerald-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{check}</span>
          </li>
        ))}
      </ul>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-xl bg-[var(--color-whatsapp)] px-6 py-3.5 text-sm font-bold text-white transition hover:bg-[var(--color-whatsapp-hover)] md:px-7 md:py-4 md:text-base"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.868-2.03-.967-.272-.099-.47-.148-.668.148-.198.297-.767.967-.94 1.165-.173.198-.346.223-.643.074-.297-.149-1.255-.463-2.39-1.475-.882-.788-1.478-1.761-1.65-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.496.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.569-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.82 11.82 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.8 11.8 0 0 0-3.48-8.413z"/></svg>
          {ctaLabel}
        </a>
        <a
          href={phoneUrl}
          class="inline-flex min-h-12 items-center justify-center gap-2 rounded-xl border border-white/35 bg-white/12 px-5 py-3.5 text-sm font-bold text-white backdrop-blur-sm transition hover:bg-white/20"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          {callLabel}
        </a>
      </div>
      <p class="mt-3 text-xs font-semibold uppercase tracking-[0.08em] text-slate-300">
        {commercialNotice}
      </p>
    </div>

    <aside class="animate-on-scroll is-visible delay-100 rounded-2xl border border-white/35 bg-white/92 p-6 shadow-[0_14px_34px_rgba(4,15,27,0.28)] backdrop-blur-sm md:p-8">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-brand-soft)]">{responseTimeLabel}</p>
      <p class="mt-3 text-3xl font-extrabold leading-[1] text-[var(--color-text)]">Atencion directa para diagnostico y presupuesto.</p>
      <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">Envia la falla y coordinamos visita.</p>

      <div class="mt-6 grid grid-cols-2 gap-3">
        <div class="panel-soft px-4 py-3">
          <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-[var(--color-text-muted)]">Servicio fuerte</p>
          <p class="mt-1 text-sm font-extrabold text-[var(--color-text)]">Aire automotor</p>
        </div>
        <div class="panel-soft px-4 py-3">
          <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-[var(--color-text-muted)]">Cobertura</p>
          <p class="mt-1 text-sm font-extrabold text-[var(--color-text)]">Gran Mendoza</p>
        </div>
      </div>

      <div class="mt-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-4 py-3">
        <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-[var(--color-text-muted)]">Cobertura activa</p>
        <div class="mt-2 flex items-center gap-2">
          <span class="h-2.5 w-2.5 rounded-full bg-[var(--color-whatsapp)]"></span>
          <p class="text-sm font-semibold text-[var(--color-text)]">{locationLabel}</p>
        </div>
      </div>
    </aside>
  </div>
</section>
