---
interface Props {
  businessName: string;
  h1: string;
  descriptor: string;
  subtitle: string;
  locationLabel: string;
  responseTimeLabel: string;
  checks: string[];
  whatsappUrl: string;
  ctaLabel: string;
}

const {
  businessName,
  h1,
  descriptor,
  subtitle,
  locationLabel,
  responseTimeLabel,
  checks,
  whatsappUrl,
  ctaLabel,
} = Astro.props;
---

<section class="relative overflow-hidden py-16 md:py-24">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_10%,rgba(194,20,77,0.30),transparent_52%),radial-gradient(circle_at_80%_80%,rgba(224,74,120,0.22),transparent_45%)]"></div>
  <div class="container-shell relative grid gap-10 md:grid-cols-[1.2fr_0.8fr] md:items-center">
    <div>
      <p class="mb-3 inline-flex rounded-full border border-[var(--color-brand-soft)]/45 bg-[var(--color-brand)]/20 px-4 py-1 text-sm font-semibold">
        {businessName}
      </p>
      <h1 class="text-3xl font-extrabold leading-tight md:text-5xl">{h1}</h1>
      <p class="mt-4 text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-soft)]">{descriptor}</p>
      <p class="mt-4 max-w-xl text-base text-[var(--color-text-muted)] md:text-lg">{subtitle}</p>
      <p class="mt-4 text-sm text-[var(--color-text-muted)]">{locationLabel}</p>
      <ul class="mt-5 grid gap-2 text-sm font-semibold text-[var(--color-text)] sm:grid-cols-2">
        {checks.map((check) => (
          <li class="flex items-start gap-2">
            <span class="mt-1 inline-block h-2 w-2 rounded-full bg-[var(--color-whatsapp)]"></span>
            <span>{check}</span>
          </li>
        ))}
      </ul>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        class="mt-8 inline-flex rounded-xl bg-[var(--color-whatsapp)] px-6 py-3 font-bold text-white transition hover:bg-[var(--color-whatsapp-hover)]"
      >
        {ctaLabel}
      </a>
    </div>
    <aside class="rounded-2xl border border-white/10 bg-[var(--color-surface)]/85 p-6 backdrop-blur">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-soft)]">{responseTimeLabel}</p>
      <p class="mt-3 text-lg font-bold">Atencion por WhatsApp para urgencias y presupuestos.</p>
      <p class="mt-3 text-sm text-[var(--color-text-muted)]">
        En menos de dos pasos el cliente puede escribir, enviar fotos y recibir una respuesta clara.
      </p>
      <div class="mt-5 rounded-xl border border-white/10 bg-black/20 p-4">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)]">Cobertura</p>
        <p class="mt-2 text-sm font-semibold">{locationLabel}</p>
      </div>
    </aside>
  </div>
</section>
