---
import SectionTitle from '../ui/SectionTitle.astro';
import { Image } from 'astro:assets';
import type { GalleryItem } from '../../content/types';

interface Props {
  images: GalleryItem[];
}

const { images } = Astro.props;

const localImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/gallery/*.{jpeg,jpg,png,gif,webp}', { eager: true });

const getImageMetadata = (srcPath: string) => {
  const filename = srcPath.split('/').pop();
  if (!filename) return null;
  const match = Object.keys(localImages).find((path) => path.endsWith('/' + filename));
  return match ? localImages[match].default : null;
};
---

<section class="py-14" id="trabajos">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Trabajos"
      title="Muestras de servicios realizados"
      description="Casos reales de atención técnica en refrigeración automotor y equipos de frío."
    />

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {images.map((image, index) => {
        const metadata = getImageMetadata(image.src);

        return (
          <figure class={`animate-on-scroll overflow-hidden rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] shadow-sm delay-${(index % 4) * 100}`}>
            <button
              type="button"
              class="relative h-48 w-full overflow-hidden text-left"
              onclick={`const d = document.getElementById('lightbox-${index}'); if (d) d.showModal();`}
              aria-label={`Abrir imagen: ${image.alt}`}
            >
              {metadata ? (
                <Image
                  src={metadata}
                  alt={image.alt}
                  width={600}
                  class="js-gallery-image h-48 w-full object-cover transition-transform duration-300 hover:scale-105"
                />
              ) : (
                <img
                  src="/images/placeholder-work.svg"
                  alt={image.alt}
                  loading="lazy"
                  decoding="async"
                  width="600"
                  data-fallback-src="/images/placeholder-work.svg"
                  class="js-gallery-image h-48 w-full object-cover transition-transform duration-300 hover:scale-105"
                />
              )}
              <span class="absolute bottom-3 right-3 rounded-md bg-[var(--color-text)]/75 px-2 py-1 text-[11px] font-bold uppercase tracking-[0.08em] text-white">
                Ver
              </span>
            </button>
          </figure>
        );
      })}
    </div>
  </div>
</section>

{images.map((image, index) => {
  const metadata = getImageMetadata(image.src);
  return (
    <dialog
      id={`lightbox-${index}`}
      class="js-lightbox-dialog m-auto max-h-[95vh] max-w-[95vw] rounded-xl border border-white/10 bg-transparent p-0 outline-none backdrop:bg-black/85"
    >
      <div class="relative flex h-full w-full flex-col items-center justify-center p-4">
        <button
          onclick={`document.getElementById('lightbox-${index}').close()`}
          class="absolute -top-12 right-0 cursor-pointer rounded-full bg-black/60 p-2 text-white/80 transition-colors hover:text-white md:-right-12 md:top-0"
          aria-label="Cerrar imagen ampliada"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>

        {metadata ? (
          <Image
            src={metadata}
            alt={image.alt}
            width={1200}
            class="max-h-[85vh] w-auto max-w-full rounded-lg border border-white/15 object-contain"
          />
        ) : (
          <img
            src="/images/placeholder-work.svg"
            alt={image.alt}
            class="max-h-[85vh] w-auto max-w-full rounded-lg border border-white/15 object-contain"
          />
        )}
        <p class="mt-4 max-w-2xl px-4 text-center text-sm font-medium text-white md:text-base">{image.alt}</p>
      </div>
    </dialog>
  );
})}

<script is:inline>
  document.querySelectorAll('.js-gallery-image').forEach((image) => {
    image.addEventListener('error', () => {
      const fallback = image.getAttribute('data-fallback-src');
      if (fallback && image.getAttribute('src') !== fallback) {
        image.setAttribute('src', fallback);
      }
    });
  });

  document.querySelectorAll('.js-lightbox-dialog').forEach((dialog) => {
    dialog.addEventListener('click', (ev) => {
      if (ev.target === dialog) {
        dialog.close();
      }
    });
  });
</script>
