---
interface Props {
  whatsappUrl: string;
  phoneUrl: string;
  label: string;
  callLabel: string;
  urgencyLabel: string;
  warrantyLabel: string;
}

const { whatsappUrl, phoneUrl, label, callLabel, urgencyLabel, warrantyLabel } = Astro.props;
---

<section class="py-16">
  <div class="container-shell">
    <div class="relative overflow-hidden rounded-3xl border border-[var(--color-brand-soft)]/30 bg-gradient-to-br from-[var(--color-brand)] to-[#460a1d] p-8 text-white md:p-12 shadow-2xl">
      <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/5 blur-3xl"></div>
      <div class="relative z-10 max-w-3xl">
        <h2 class="text-3xl font-black leading-tight md:text-4xl text-white">¿Necesitás resolver un equipo hoy?</h2>
        <p class="mt-4 text-lg text-white/90 font-medium">
          Escribí por WhatsApp, contá el problema y te daremos una respuesta clara para coordinar una visita inmediata.
        </p>
        
        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noreferrer"
            class="group inline-flex items-center justify-center gap-2.5 rounded-2xl bg-[var(--color-whatsapp)] px-8 py-4 font-bold text-white shadow-lg transition-all hover:-translate-y-1 hover:bg-[var(--color-whatsapp-hover)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="size-5 transition-transform group-hover:scale-110">
              <path d="M17.472 14.382c-.297-.149-1.758-.868-2.03-.967-.272-.099-.47-.148-.668.148-.198.297-.767.967-.94 1.165-.173.198-.346.223-.643.074-.297-.149-1.255-.463-2.39-1.475-.882-.788-1.478-1.761-1.65-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.496.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.569-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.82 11.82 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.8 11.8 0 0 0-3.48-8.413z"/></svg>
            {label}
          </a>
          <a
            href={phoneUrl}
            class="inline-flex items-center justify-center gap-2 rounded-2xl border border-white/20 bg-white/5 px-8 py-4 font-bold text-white backdrop-blur-sm transition-all hover:bg-white/10 hover:border-white/40"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            {callLabel}
          </a>
        </div>
        
        <div class="mt-10 flex flex-wrap gap-x-8 gap-y-4 pt-10 border-t border-white/10">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-white/60">Garantía Asegurada</p>
              <p class="text-sm font-bold text-white">{warrantyLabel}</p>
            </div>
          </div>
          
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider text-white/60">Servicio de Urgencia</p>
              <p class="text-sm font-bold text-white">{urgencyLabel}</p>
            </div>
          </div>
          
          <div class="flex items-center gap-3 ml-auto sm:ml-0">
             <p class="text-sm font-medium text-white/80 italic">Atención personalizada en Maipú, Luján y Gran Mendoza.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
