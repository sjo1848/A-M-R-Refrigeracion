---
interface Props {
  whatsappUrl: string;
  label: string;
  phoneLabel: string;
  urgencyLabel: string;
  warrantyLabel: string;
}

const { whatsappUrl, label, phoneLabel, urgencyLabel, warrantyLabel } = Astro.props;
---

<section class="py-16">
  <div class="container-shell">
    <div class="rounded-3xl border border-[var(--color-brand-soft)]/50 bg-[linear-gradient(160deg,rgba(194,20,77,0.86),rgba(70,10,29,0.95))] p-8 text-white md:p-10">
      <h2 class="text-2xl font-extrabold md:text-3xl">Necesitas resolver un equipo hoy?</h2>
      <p class="mt-3 max-w-2xl text-slate-100">
        Escribi por WhatsApp, conta el problema y enviamos una respuesta clara para coordinar visita.
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noreferrer"
          class="inline-flex rounded-xl bg-[var(--color-whatsapp)] px-6 py-3 font-bold text-white transition hover:bg-[var(--color-whatsapp-hover)]"
        >
          {label}
        </a>
        <p class="text-sm font-semibold text-slate-100">WhatsApp directo: {phoneLabel}</p>
      </div>
      <p class="mt-5 text-xs font-semibold uppercase tracking-[0.12em] text-slate-100/85">{urgencyLabel}</p>
      <p class="mt-1 text-xs font-semibold uppercase tracking-[0.12em] text-slate-100/85">{warrantyLabel}</p>
    </div>
  </div>
</section>
