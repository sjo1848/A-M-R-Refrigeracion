---
import { Image } from 'astro:assets';
import defaultCtaBackground from '../../assets/gallery/amr-03.jpg';

interface Props {
  whatsappUrl: string;
  phoneUrl: string;
  label: string;
  callLabel: string;
  urgencyLabel: string;
  warrantyLabel: string;
  topServiceLabel?: string;
  serviceConditions?: string[];
  backgroundImage?: ImageMetadata;
}

const {
  whatsappUrl,
  phoneUrl,
  label,
  callLabel,
  urgencyLabel,
  warrantyLabel,
  topServiceLabel = 'Aire acondicionado automotor',
  serviceConditions = [],
  backgroundImage = defaultCtaBackground,
} = Astro.props;
---

<section class="relative isolate overflow-hidden py-16">
  <Image
    src={backgroundImage}
    alt=""
    widths={[640, 900, 1200, 1500]}
    sizes="(max-width: 768px) 100vw, 1200px"
    loading="lazy"
    decoding="async"
    width={1500}
    class="absolute inset-0 -z-20 h-full w-full object-cover"
  />
  <div class="absolute inset-0 -z-10 bg-[linear-gradient(110deg,rgba(4,18,32,0.84)_0%,rgba(7,30,48,0.7)_52%,rgba(6,26,42,0.66)_100%)]"></div>

  <div class="container-shell">
    <div class="rounded-2xl border border-white/30 bg-white/92 p-8 shadow-[0_14px_34px_rgba(4,15,27,0.28)] backdrop-blur-sm md:p-12">
      <div class="max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--color-brand-soft)]">Contacto tecnico</p>
        <h2 class="mt-3 text-[2.35rem] font-black leading-[0.93] text-[var(--color-text)] sm:text-5xl">Necesitas resolver un equipo hoy?</h2>
        <p class="mt-4 text-lg font-medium text-[var(--color-text-muted)]">Escribi por WhatsApp y coordinamos rapido.</p>

        <div class="mt-5 inline-flex items-center gap-2 rounded-md border border-[var(--color-brand-soft)]/40 bg-[var(--color-brand-soft)]/10 px-3 py-1.5 text-[11px] font-bold uppercase tracking-[0.12em] text-[var(--color-brand)]">
          <span class="h-2 w-2 rounded-full bg-[var(--color-brand-soft)]"></span>
          Servicio con mas demanda: {topServiceLabel}
        </div>

        <div class="mt-4 flex flex-wrap gap-2">
          <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.08em] text-[var(--color-text)]">Residencial</span>
          <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.08em] text-[var(--color-text)]">Comercial</span>
          <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.08em] text-[var(--color-text)]">Automotor</span>
        </div>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noreferrer"
            class="inline-flex min-h-12 items-center justify-center gap-2.5 rounded-xl bg-[var(--color-whatsapp)] px-7 py-3.5 text-sm font-bold text-white transition hover:bg-[var(--color-whatsapp-hover)] md:px-8 md:py-4 md:text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="size-5">
              <path d="M17.472 14.382c-.297-.149-1.758-.868-2.03-.967-.272-.099-.47-.148-.668.148-.198.297-.767.967-.94 1.165-.173.198-.346.223-.643.074-.297-.149-1.255-.463-2.39-1.475-.882-.788-1.478-1.761-1.65-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.496.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.569-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.82 9.82 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.82 11.82 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.88 11.88 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.8 11.8 0 0 0-3.48-8.413z"/>
            </svg>
            {label}
          </a>
          <a
            href={phoneUrl}
            class="inline-flex min-h-12 items-center justify-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-7 py-3.5 text-sm font-bold text-[var(--color-text)] transition hover:border-[var(--color-brand-soft)] md:px-8 md:py-4 md:text-base"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            {callLabel}
          </a>
        </div>

        <div class="mt-8 grid gap-3 border-t border-[var(--color-border)] pt-6 text-sm md:grid-cols-2">
          <p class="panel-soft px-4 py-3 font-semibold text-[var(--color-text)]">
            <span class="mr-2 text-[var(--color-brand-soft)]">Garantia:</span>{warrantyLabel}
          </p>
          <p class="panel-soft px-4 py-3 font-semibold text-[var(--color-text)]">
            <span class="mr-2 text-[var(--color-brand-soft)]">Urgencias:</span>{urgencyLabel}
          </p>
        </div>

        {serviceConditions.length > 0 && (
          <div class="mt-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-soft)]/70 p-4">
            <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-[var(--color-brand-soft)]">
              Condiciones de servicio
            </p>
            <ul class="mt-2 space-y-1.5 text-xs leading-relaxed text-[var(--color-text-muted)]">
              {serviceConditions.slice(0, 2).map((condition) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-brand-soft)]"></span>
                  <span>{condition}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
