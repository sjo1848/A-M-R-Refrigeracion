---
interface Props {
  whatsappUrl: string;
}

const { whatsappUrl } = Astro.props;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noreferrer"
  aria-label="Abrir WhatsApp"
  class="fixed bottom-5 right-5 z-50 inline-flex items-center gap-2 rounded-full bg-[var(--color-whatsapp)] px-5 py-3 text-sm font-extrabold text-white shadow-[0_8px_24px_rgba(0,0,0,0.45)] transition hover:bg-[var(--color-whatsapp-hover)]"
>
  <span class="inline-block h-2 w-2 rounded-full bg-white"></span>
  <span>WhatsApp</span>
</a>
