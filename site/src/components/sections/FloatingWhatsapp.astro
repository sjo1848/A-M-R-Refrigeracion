---
interface Props {
  whatsappUrl: string;
}

const { whatsappUrl } = Astro.props;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noreferrer"
  aria-label="Abrir WhatsApp"
  class="fixed bottom-5 right-5 z-50 hidden items-center gap-2 rounded-full bg-[var(--color-whatsapp)] px-4 py-2.5 text-sm font-extrabold text-white shadow-[0_8px_22px_rgba(0,0,0,0.25)] transition hover:bg-[var(--color-whatsapp-hover)] md:inline-flex"
>
  <span class="inline-block h-2 w-2 rounded-full bg-white"></span>
  <span>WhatsApp</span>
</a>
