---
import SectionTitle from '../ui/SectionTitle.astro';
import type { ServiceDetail } from '../../content/types';

interface Props {
  services: ServiceDetail[];
  whatsappUrl: string;
  ctaLabel: string;
}

const { services, whatsappUrl, ctaLabel } = Astro.props;

const topServiceSlug = 'aire-acondicionado-automotor-mendoza';
const featuredService = services.find((service) => service.slug === topServiceSlug) ?? services[0];
const secondaryServices = services.filter((service) => service.slug !== featuredService.slug);
---

<section class="py-14 md:py-18" id="servicios">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Servicios"
      title="Soluciones en refrigeracion para hogar, comercio y automotor"
      description="Priorizado para resolver rapido y evitar perdida de tiempo en diagnosticos confusos."
    />

    <article class="animate-on-scroll panel mb-6 overflow-hidden p-6 md:p-8">
      <p class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-brand-soft)]">Servicio mas solicitado</p>
      <div class="mt-3 grid gap-6 md:grid-cols-[1.1fr_0.9fr] md:items-center">
        <div>
          <h3 class="text-3xl font-extrabold leading-[1] text-[var(--color-text)] md:text-4xl">{featuredService.title}</h3>
          <p class="mt-3 text-[var(--color-text-muted)]">{featuredService.description}</p>
          <ul class="mt-4 grid gap-2 text-sm text-[var(--color-text-muted)] sm:grid-cols-2">
            {featuredService.features.slice(0, 4).map((feature: string) => (
              <li class="flex items-start gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-soft)]/70 px-3 py-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-[var(--color-brand-soft)]"></span>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="flex flex-col gap-3">
          <a
            href={`/servicios/${featuredService.slug}`}
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-[var(--color-brand)] px-6 py-3 text-sm font-bold uppercase tracking-[0.04em] text-white transition hover:opacity-90"
          >
            Ver servicio destacado
          </a>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-6 py-3 text-sm font-bold text-[var(--color-text)] transition hover:border-[var(--color-brand-soft)]"
          >
            Consultar por WhatsApp
          </a>
        </div>
      </div>
    </article>

    <div class="grid gap-5 md:grid-cols-2">
      {secondaryServices.map((service, index) => (
        <a
          href={`/servicios/${service.slug}`}
          class:list={[
            'block animate-on-scroll rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition-all duration-200 hover:-translate-y-1 hover:border-[var(--color-brand-soft)]/40 hover:shadow-[var(--shadow-card-hover)]',
            `delay-${(index % 3) * 100}`
          ]}
        >
          <h3 class="text-2xl font-extrabold leading-[1.05] text-[var(--color-text)]">{service.title}</h3>
          <ul class="mt-4 space-y-2 text-sm text-[var(--color-text-muted)]">
            {service.features.slice(0, 4).map((feature: string) => (
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-[var(--color-brand-soft)]"></span>
                <span class="line-clamp-1">{feature}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-[var(--color-brand-soft)]">
            Ver mas detalles
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.3" stroke="currentColor" class="size-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        class="inline-flex rounded-xl bg-[var(--color-whatsapp)] px-6 py-3 text-sm font-extrabold text-white transition hover:bg-[var(--color-whatsapp-hover)] md:text-base"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</section>
