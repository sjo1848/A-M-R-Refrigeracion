---
import SectionTitle from '../ui/SectionTitle.astro';
import type { ServiceDetail } from '../../content/types';

interface Props {
  services: ServiceDetail[];
  whatsappUrl: string;
  ctaLabel: string;
}

const { services, whatsappUrl, ctaLabel } = Astro.props;
---

<section class="py-14 md:py-18" id="servicios">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Servicios"
      title="Soluciones en refrigeracion para hogar, comercio y automotor"
      description="Priorizado para resolver rapido y evitar perdida de tiempo en diagnosticos confusos."
    />
    <div class="grid gap-5 md:grid-cols-3">
      {services.map((service, index) => (
        <a
          href={`/servicios/${service.slug}`}
          class:list={[
            'block animate-on-scroll rounded-[1.5rem] border p-7 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-2xl overflow-hidden relative group',
            index === 0 // Solo al primer item le damos prioridad alta visualmente
              ? 'border-[var(--color-brand-soft)]/60 bg-gradient-to-b from-[var(--color-brand)]/10 to-[var(--color-surface)] hover:shadow-[var(--color-brand)]/20'
              : 'border-white/10 bg-[var(--color-surface)]/80 backdrop-blur hover:bg-[var(--color-surface-soft)] hover:shadow-white/5',
            `delay-${(index % 3) * 100}`
          ]}
        >
          {index === 0 && (
            <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100 pointer-events-none"></div>
          )}
          <h3 class="text-lg font-extrabold text-[var(--color-text)] group-hover:text-[var(--color-brand-soft)] transition-colors">{service.title}</h3>
          {index === 0 && (
            <p class="mt-2 text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-brand-soft)]">Especialidad de la casa</p>
          )}
          <ul class="mt-4 space-y-2 text-sm text-[var(--color-text-muted)]">
            {service.features.slice(0, 4).map((feature: string) => (
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-[var(--color-whatsapp)]"></span>
                <span class="line-clamp-1">{feature}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 font-bold text-sm text-[var(--color-brand-soft)] flex items-center gap-2 group-hover:translate-x-1 transition-transform">
            Ver más detalles
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-8">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        class="inline-flex rounded-xl bg-[var(--color-whatsapp)] px-6 py-3 text-sm font-extrabold text-white transition hover:bg-[var(--color-whatsapp-hover)] md:text-base"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</section>
