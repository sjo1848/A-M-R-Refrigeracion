---
import SectionTitle from '../ui/SectionTitle.astro';
import type { Testimonial } from '../../content/types';

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;

const getInitials = (name: string) => {
  const parts = name.split(' ');
  if (parts.length >= 2) {
    return `${parts[0][0]}${parts[1][0]}`.toUpperCase();
  }
  return name.slice(0, 2).toUpperCase();
};
---

<section class="py-14" id="testimonios">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Confianza"
      title="Opiniones de clientes"
      description="Referencias de atención técnica, tiempos de respuesta y claridad en el trabajo realizado."
    />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((item) => (
        <article class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 shadow-sm">
          <div class="mb-4 flex items-center justify-between gap-3">
            <div class="flex gap-1 text-yellow-500">
              {[1, 2, 3, 4, 5].map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            {item.service && (
              <span class="rounded-md border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-2 py-1 text-[10px] font-bold uppercase tracking-[0.1em] text-[var(--color-text)]">
                {item.service}
              </span>
            )}
          </div>

          <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">"{item.quote}"</p>

          <div class="mt-5 flex items-center justify-between gap-3 border-t border-[var(--color-border)] pt-4">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[var(--color-brand-soft)]/18 text-sm font-bold text-[var(--color-brand)]">
                {getInitials(item.name)}
              </div>
              <div>
                <p class="text-sm font-bold text-[var(--color-text)]">{item.name}</p>
                <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-soft)]">{item.area}</p>
              </div>
            </div>
            <p class="text-[10px] font-bold uppercase tracking-[0.1em] text-[var(--color-text-muted)]">Caso real</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
