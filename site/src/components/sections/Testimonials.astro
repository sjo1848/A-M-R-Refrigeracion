---
import SectionTitle from '../ui/SectionTitle.astro';
import type { Testimonial } from '../../content/types';

interface Props {
  testimonials: Testimonial[];
}

const { testimonials } = Astro.props;
---

<section class="py-14" id="testimonios">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Confianza"
      title="Opiniones de clientes"
      description="Bloque provisional para sprint 1.2 con testimonios finales validados."
    />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((item) => (
        <article class="rounded-2xl border border-white/10 bg-[var(--color-surface)] p-6">
          <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">"{item.quote}"</p>
          <p class="mt-4 text-sm font-bold text-[var(--color-text)]">{item.name}</p>
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-soft)]">{item.area}</p>
        </article>
      ))}
    </div>
  </div>
</section>
