---
import SectionTitle from '../ui/SectionTitle.astro';
import type { FaqItem } from '../../content/types';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="py-14" id="faq">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Preguntas frecuentes"
      title="Respuestas rápidas antes de contactarte"
      description="Lo justo antes de contactarte."
    />
    <div class="mx-auto max-w-3xl space-y-4">
      {items.slice(0, 4).map((item, index) => (
        <details class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] transition-colors open:border-[var(--color-brand-soft)]/40" open={index === 0}>
          <summary class="flex cursor-pointer list-none items-center justify-between p-6 text-base font-bold text-[var(--color-text)] select-none">
            <span class="pr-6">{item.question}</span>
            <span class="shrink-0 text-[var(--color-brand-soft)] transition-transform duration-300 group-open:rotate-180">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6 text-sm leading-relaxed text-[var(--color-text-muted)]">
            <div class="border-t border-[var(--color-border)] pt-2">
              {item.answer}
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
