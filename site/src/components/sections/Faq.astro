---
import SectionTitle from '../ui/SectionTitle.astro';
import type { FaqItem } from '../../content/types';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="py-14" id="faq">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Preguntas frecuentes"
      title="Respuestas rapidas antes de contactarte"
      description="Bloque pensado para reducir friccion y acelerar consultas utiles."
    />
    <div class="space-y-3">
      {items.map((item, index) => (
        <details class="group rounded-xl border border-white/10 bg-[var(--color-surface)] p-4" open={index === 0}>
          <summary class="cursor-pointer list-none pr-6 text-sm font-bold text-[var(--color-text)]">
            {item.question}
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-muted)]">{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
