---
import SectionTitle from '../ui/SectionTitle.astro';
import type { FaqItem } from '../../content/types';

interface Props {
  items: FaqItem[];
}

const { items } = Astro.props;
---

<section class="py-14" id="faq">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Preguntas frecuentes"
      title="Respuestas rápidas antes de contactarte"
      description="Resolvemos tus dudas iniciales para que el proceso sea más ágil y transparente."
    />
    <div class="max-w-3xl mx-auto space-y-4">
      {items.map((item, index) => (
        <details class="group rounded-2xl border border-black/5 dark:border-white/10 bg-[var(--color-surface)] transition-all duration-300 open:shadow-xl dark:open:shadow-white/5" open={index === 0}>
          <summary class="flex items-center justify-between cursor-pointer list-none p-6 text-base font-bold text-[var(--color-text)] select-none">
            <span class="pr-6">{item.question}</span>
            <span class="shrink-0 transition-transform duration-300 group-open:rotate-180 text-[var(--color-brand-soft)]">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6 text-sm leading-relaxed text-[var(--color-text-muted)] animate-in fade-in slide-in-from-top-2 duration-300">
            <div class="pt-2 border-t border-black/5 dark:border-white/5">
              {item.answer}
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

