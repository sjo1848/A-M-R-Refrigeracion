---
interface Props {
  brandName: string;
  whatsappUrl: string;
  phoneUrl: string;
  callLabel: string;
}

const { brandName, whatsappUrl, phoneUrl, callLabel } = Astro.props;
---

<header class="fixed top-0 z-50 w-full border-b border-[var(--color-border)] bg-[var(--color-bg)]/94 backdrop-blur">
  <div class="container-shell flex items-center justify-between gap-4 py-3">
    <a href="/" class="group">
      <p class="text-sm font-extrabold uppercase tracking-[0.12em] text-[var(--color-text)] transition-colors group-hover:text-[var(--color-brand-soft)]">
        {brandName}
      </p>
      <p class="hidden text-[11px] font-semibold uppercase tracking-[0.1em] text-[var(--color-text-muted)] md:block">
        Refrigeracion profesional en Mendoza
      </p>
    </a>

    <nav class="hidden items-center gap-5 text-sm font-semibold text-[var(--color-text-muted)] md:flex">
      <a href="#servicios" class="transition-colors hover:text-[var(--color-brand-soft)]">Servicios</a>
      <a href="#credenciales" class="transition-colors hover:text-[var(--color-brand-soft)]">Credenciales</a>
      <a href="#proceso" class="transition-colors hover:text-[var(--color-brand-soft)]">Proceso</a>
      <a href="#especialidades" class="transition-colors hover:text-[var(--color-brand-soft)]">Especialidades</a>
      <a href="#zonas" class="transition-colors hover:text-[var(--color-brand-soft)]">Zonas</a>
      <a href="#faq" class="transition-colors hover:text-[var(--color-brand-soft)]">FAQ</a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={phoneUrl}
        class="inline-flex items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-xs font-bold text-[var(--color-text)] transition-colors hover:border-[var(--color-brand-soft)] hover:text-[var(--color-brand-soft)] md:text-sm"
      >
        {callLabel}
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        class="hidden rounded-lg bg-[var(--color-whatsapp)] px-4 py-2 text-xs font-bold text-white transition hover:bg-[var(--color-whatsapp-hover)] md:inline-flex md:text-sm"
      >
        WhatsApp directo
      </a>
    </div>
  </div>
</header>
