---
interface Props {
  brandName: string;
  whatsappUrl: string;
  phoneUrl: string;
  callLabel: string;
}

const { brandName, whatsappUrl, phoneUrl, callLabel } = Astro.props;

const navLinks = [
  { href: '#trabajos', label: 'Trabajos' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#credenciales', label: 'Credenciales' },
  { href: '#cobertura', label: 'Cobertura' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="fixed top-0 z-50 w-full border-b border-[var(--color-border)] bg-[var(--color-bg)]/94 backdrop-blur">
  <div class="container-shell flex items-center justify-between gap-3 py-3">
    <a href="/" class="group min-w-0">
      <p class="truncate text-sm font-extrabold uppercase tracking-[0.12em] text-[var(--color-text)] transition-colors group-hover:text-[var(--color-brand-soft)]">
        {brandName}
      </p>
      <p class="hidden text-[11px] font-semibold uppercase tracking-[0.1em] text-[var(--color-text-muted)] md:block">
        Refrigeracion profesional en Mendoza
      </p>
    </a>

    <nav class="hidden items-center gap-5 text-sm font-semibold text-[var(--color-text-muted)] md:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="transition-colors hover:text-[var(--color-brand-soft)]">{link.label}</a>
      ))}
    </nav>

    <div class="hidden items-center gap-2 md:flex">
      <a
        href={phoneUrl}
        class="inline-flex items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-xs font-bold text-[var(--color-text)] transition-colors hover:border-[var(--color-brand-soft)] hover:text-[var(--color-brand-soft)] md:text-sm"
      >
        {callLabel}
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        class="rounded-lg bg-[var(--color-whatsapp)] px-4 py-2 text-xs font-bold text-white transition hover:bg-[var(--color-whatsapp-hover)] md:text-sm"
      >
        Pedir presupuesto
      </a>
    </div>

    <div class="flex items-center gap-2 md:hidden">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noreferrer"
        aria-label="Pedir presupuesto por WhatsApp"
        class="inline-flex h-10 items-center justify-center rounded-lg bg-[var(--color-whatsapp)] px-3 text-xs font-bold text-white"
      >
        WhatsApp
      </a>
      <button
        id="mobile-menu-open"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] text-[var(--color-text)]"
        aria-controls="mobile-drawer"
        aria-expanded="false"
        aria-label="Abrir menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5m-16.5 5.25h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </div>
</header>

<div id="mobile-drawer" class="pointer-events-none fixed inset-0 z-[60] hidden md:hidden">
  <button id="mobile-drawer-backdrop" class="absolute inset-0 bg-black/45 opacity-0 transition-opacity" aria-label="Cerrar menu"></button>
  <aside id="mobile-drawer-panel" class="absolute right-0 top-0 h-full w-[86%] max-w-sm translate-x-full border-l border-[var(--color-border)] bg-[var(--color-surface)] p-5 shadow-2xl transition-transform duration-300">
    <div class="flex items-center justify-between gap-3 border-b border-[var(--color-border)] pb-4">
      <p class="text-sm font-extrabold uppercase tracking-[0.12em] text-[var(--color-text)]">Menu</p>
      <button id="mobile-menu-close" type="button" class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--color-border)] text-[var(--color-text)]" aria-label="Cerrar menu">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="mt-4 grid gap-1" aria-label="Navegacion principal mobile">
      {navLinks.map((link) => (
        <a href={link.href} class="js-drawer-link rounded-lg px-3 py-3 text-sm font-bold text-[var(--color-text)] transition-colors hover:bg-[var(--color-surface-soft)]">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="mt-5 grid gap-2 border-t border-[var(--color-border)] pt-4">
      <a href={phoneUrl} class="inline-flex min-h-11 items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-3 py-2 text-sm font-bold text-[var(--color-text)]">
        {callLabel}
      </a>
      <a href={whatsappUrl} target="_blank" rel="noreferrer" class="inline-flex min-h-11 items-center justify-center rounded-lg bg-[var(--color-whatsapp)] px-3 py-2 text-sm font-bold text-white">
        Pedir presupuesto
      </a>
    </div>
  </aside>
</div>

<script>
  const drawer = document.getElementById('mobile-drawer');
  const panel = document.getElementById('mobile-drawer-panel');
  const backdrop = document.getElementById('mobile-drawer-backdrop');
  const openBtn = document.getElementById('mobile-menu-open');
  const closeBtn = document.getElementById('mobile-menu-close');
  const linkBtns = document.querySelectorAll('.js-drawer-link');

  const openDrawer = () => {
    if (!drawer || !panel || !backdrop || !openBtn) return;
    drawer.classList.remove('hidden', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => {
      panel.classList.remove('translate-x-full');
      backdrop.classList.remove('opacity-0');
    });
    openBtn.setAttribute('aria-expanded', 'true');
  };

  const closeDrawer = () => {
    if (!drawer || !panel || !backdrop || !openBtn) return;
    panel.classList.add('translate-x-full');
    backdrop.classList.add('opacity-0');
    openBtn.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    setTimeout(() => {
      drawer.classList.add('hidden', 'pointer-events-none');
    }, 260);
  };

  openBtn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);
  linkBtns.forEach((link) => link.addEventListener('click', closeDrawer));

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeDrawer();
  });
</script>
