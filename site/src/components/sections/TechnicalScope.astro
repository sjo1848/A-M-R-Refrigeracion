---
import SectionTitle from '../ui/SectionTitle.astro';
import type { TechnicalScopeItem } from '../../content/types';

interface Props {
  items: TechnicalScopeItem[];
}

const { items } = Astro.props;
---

<section class="py-14" id="especialidades">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Especialidades tecnicas"
      title="Equipos y fallas que resolvemos todos los dias"
      description="Orientado a consultas reales: detalle tecnico sin ruido para acelerar diagnostico y presupuesto."
    />
    <div class="grid gap-6 md:grid-cols-3">
      {items.map((item) => (
        <article class="rounded-2xl border border-black/5 dark:border-white/10 bg-[var(--color-surface)] p-6 shadow-sm transition-shadow hover:shadow-md">
          <h3 class="text-lg font-extrabold text-[var(--color-text)] flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-brand-soft)]"></span>
            {item.title}
          </h3>
          <ul class="mt-5 space-y-3 text-sm text-[var(--color-text-muted)]">
            {item.points.map((point) => (
              <li class="flex gap-3 items-start">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="mt-0.5 size-3.5 shrink-0 text-[var(--color-whatsapp)]">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
