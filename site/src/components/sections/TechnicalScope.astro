---
import SectionTitle from '../ui/SectionTitle.astro';
import type { TechnicalScopeItem } from '../../content/types';

interface Props {
  items: TechnicalScopeItem[];
}

const { items } = Astro.props;
---

<section class="py-14" id="especialidades">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Especialidades tecnicas"
      title="Equipos y fallas que resolvemos todos los dias"
      description="Orientado a consultas reales: detalle tecnico sin ruido para acelerar diagnostico y presupuesto."
    />
    <div class="grid gap-5 md:grid-cols-3">
      {items.map((item) => (
        <article class="rounded-2xl border border-white/10 bg-[var(--color-surface)] p-6">
          <h3 class="text-lg font-extrabold text-[var(--color-text)]">{item.title}</h3>
          <ul class="mt-4 space-y-2 text-sm text-[var(--color-text-muted)]">
            {item.points.map((point) => (
              <li class="flex gap-2">
                <span class="mt-1 inline-block h-2 w-2 rounded-full bg-[var(--color-whatsapp)]"></span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
