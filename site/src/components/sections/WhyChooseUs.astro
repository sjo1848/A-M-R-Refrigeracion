---
import SectionTitle from '../ui/SectionTitle.astro';
import type { WhyChoosePoint } from '../../content/types';

interface Props {
  points: WhyChoosePoint[];
}

const { points } = Astro.props;
---

<section class="py-14" id="diferenciales">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Por que elegir A.M.R"
      title="Diferenciales que mejoran la confianza antes de escribir"
      description="Bloque orientado a conversion con experiencia, claridad tecnica y reglas operativas transparentes."
    />
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {points.map((point) => (
        <article class="group rounded-2xl border border-black/5 dark:border-white/10 bg-[var(--color-surface)] p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl dark:hover:shadow-white/5">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--color-brand-soft)]/10 text-[var(--color-brand-soft)] transition-colors group-hover:bg-[var(--color-brand-soft)] group-hover:text-white">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-6">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <h3 class="text-base font-extrabold text-[var(--color-text)]">{point.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{point.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
