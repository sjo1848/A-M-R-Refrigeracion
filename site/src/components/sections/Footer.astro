---
interface Props {
  brandName: string;
  businessLabel: string;
  phoneLabel: string;
  phoneUrl: string;
  addressReference: string;
  coverageLabel: string;
}

const { brandName, businessLabel, phoneLabel, phoneUrl, addressReference, coverageLabel } = Astro.props;
---

<footer class="border-t border-black/5 dark:border-white/10 bg-black/5 dark:bg-black/35 py-8">
  <div class="container-shell grid gap-6 md:grid-cols-2">
    <div>
      <p class="text-sm font-extrabold uppercase tracking-[0.14em] text-[var(--color-text)]">{brandName}</p>
      <p class="mt-3 text-sm text-[var(--color-text-muted)]">{businessLabel}</p>
    </div>
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-soft)]">Contacto y referencia</p>
      <p class="mt-2 text-sm text-[var(--color-text-muted)]">
        Telefono:
        <a href={phoneUrl} class="ml-1 font-semibold text-[var(--color-text)] hover:text-[var(--color-brand-soft)]">{phoneLabel}</a>
      </p>
      <p class="mt-1 text-sm text-[var(--color-text-muted)]">{addressReference}</p>
      <p class="mt-1 text-sm text-[var(--color-text-muted)]">{coverageLabel}</p>
    </div>
  </div>
</footer>
