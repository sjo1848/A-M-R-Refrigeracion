---
interface Props {
  brandName: string;
  businessLabel: string;
  phoneLabel: string;
  phoneUrl: string;
  addressReference: string;
  coverageLabel: string;
  serviceConditions?: string[];
  commercialNotice?: string;
}

const {
  brandName,
  businessLabel,
  phoneLabel,
  phoneUrl,
  addressReference,
  coverageLabel,
  serviceConditions = [],
  commercialNotice = '',
} = Astro.props;
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface)] py-8">
  <div class="container-shell grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    <div>
      <p class="text-sm font-extrabold uppercase tracking-[0.14em] text-[var(--color-text)]">{brandName}</p>
      <p class="mt-3 text-sm text-[var(--color-text-muted)]">{businessLabel}</p>
      {commercialNotice && (
        <p class="mt-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-soft)]/70 px-3 py-2 text-xs font-semibold text-[var(--color-text-muted)]">
          {commercialNotice}
        </p>
      )}
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-soft)]">Contacto y referencia</p>
      <p class="mt-2 text-sm text-[var(--color-text-muted)]">
        Telefono:
        <a href={phoneUrl} class="ml-1 font-semibold text-[var(--color-text)] hover:text-[var(--color-brand-soft)]">{phoneLabel}</a>
      </p>
      <p class="mt-1 text-sm text-[var(--color-text-muted)]">{addressReference}</p>
      <p class="mt-1 text-sm text-[var(--color-text-muted)]">{coverageLabel}</p>
    </div>

    {serviceConditions.length > 0 && (
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-soft)]">Condiciones de servicio</p>
        <ul class="mt-2 space-y-1.5 text-xs leading-relaxed text-[var(--color-text-muted)]">
          {serviceConditions.slice(0, 2).map((condition) => (
            <li class="flex items-start gap-2">
              <span class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-brand-soft)]"></span>
              <span>{condition}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</footer>
