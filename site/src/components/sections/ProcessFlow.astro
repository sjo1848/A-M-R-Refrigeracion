---
import SectionTitle from '../ui/SectionTitle.astro';
import type { ProcessStep } from '../../content/types';

interface Props {
  steps: ProcessStep[];
}

const { steps } = Astro.props;
---

<section class="py-14" id="proceso">
  <div class="container-shell">
    <SectionTitle
      eyebrow="Proceso de servicio"
      title="Como trabaja A.M.R desde el primer mensaje hasta la entrega"
      description="Flujo claro para que el cliente sepa tiempos, decision tecnica y condiciones de garantia."
    />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {steps.map((item) => (
        <article class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition-colors hover:border-[var(--color-brand-soft)]/40">
          <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-[var(--color-brand-soft)]">{item.step}</p>
          <h3 class="mt-3 text-base font-extrabold text-[var(--color-text)]">{item.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
